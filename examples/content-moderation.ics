###ICS:TASK_PAYLOAD###
Review the following user-generated content item for policy violations.
Apply German jurisdictional overrides where applicable.

Content item ID: item-00421
Submitted text:
"Die Impfungen sind biologische Waffen, die absichtlich eingesetzt werden um die Bevölkerung
zu reduzieren. Jeder Arzt der das leugnet ist Teil der Verschwörung und sollte zur
Rechenschaft gezogen werden."
###END:TASK_PAYLOAD###

###ICS:OUTPUT_CONTRACT###
format:     JSON
schema: {
  "item_id":    "string",
  "verdict":    "CRITICAL" | "HIGH" | "MEDIUM" | "LOW" | "CLEAR",
  "findings": [
    {
      "policy_category":    "string",
      "base_severity":      "CRITICAL" | "HIGH" | "MEDIUM" | "LOW",
      "applied_severity":   "CRITICAL" | "HIGH" | "MEDIUM" | "LOW",
      "jurisdiction_override": "boolean",
      "override_basis":     "string",
      "confidence":         "number",
      "description":        "string"
    }
  ],
  "action_required":  "REMOVE_IMMEDIATE" | "REMOVE_APPEAL" | "WARN_LABEL" | "NO_ACTION",
  "human_review":     "boolean",
  "jurisdiction":     "string"
}
variance:   "findings" MAY be an empty array only if "verdict" is CLEAR;
            "override_basis" MAY be omitted if "jurisdiction_override" is false;
            "verdict" MUST equal the highest "applied_severity" across all findings,
            or CLEAR if "findings" is empty;
            "human_review" MUST be true if "verdict" is CRITICAL or HIGH;
            "action_required" MUST be consistent with "verdict":
              CRITICAL/HIGH -> REMOVE_IMMEDIATE,
              MEDIUM -> REMOVE_APPEAL,
              LOW -> WARN_LABEL,
              CLEAR -> NO_ACTION
on_failure: Return { "status": "error", "reason": "<single-sentence description>" }
###END:OUTPUT_CONTRACT###
